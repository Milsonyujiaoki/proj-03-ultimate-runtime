# ======================================
# Main targets
# ======================================

all: $(LIB)

# ======================================
# Library
# ======================================

$(LIB): $(OBJ)
	@mkdir -p $(BUILD_DIR)
	$(AR) $(ARFLAGS) $@ $^

# ======================================
# Object compilation
# ======================================

$(OBJ_DIR)/%.o: src/%.c
	@mkdir -p $(dir $@)
	$(CC) $(CFLAGS) -c $< -o $@

# ======================================
# Cleanup
# ======================================

clean:
	rm -rf $(BUILD_DIR)
	find . -name "*.o" -delete

re: clean all

.PHONY: all clean re
