root = true

[*]
charset              = utf-8
end_of_line          = lf
indent_style         = space
indent_size          = 4
tab_width            = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.{c,h,cpp,hpp,cc,cxx,hxx}]
indent_style = space
indent_size  = 4

[*.{cmake,CMakeLists}]
indent_style = space
indent_size  = 2

[CMakeLists.txt]
indent_style = space
indent_size  = 2

[*.{yml,yaml}]
indent_style = space
indent_size  = 2

[*.{json,jsonc}]
indent_style = space
indent_size  = 2

[*.{py}]
indent_style = space
indent_size  = 4

[*.{sh,bash}]
indent_style = space
indent_size  = 2

[Makefile]
indent_style = tab
tab_width    = 4

[*.md]
trim_trailing_whitespace = false

[*.{toml}]
indent_style = space
indent_size  = 2
