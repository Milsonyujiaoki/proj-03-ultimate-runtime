# =============================================================================
# .gitignore — ultimate-runtime
# =============================================================================

# ── CMake build artifacts ─────────────────────────────────────────────────────
build/
out/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
CTestTestfile.cmake
_deps/
*.cmake.user

# ── Compiled objects ──────────────────────────────────────────────────────────
*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exe
*.out
*.app
*.pdb
*.ilk
*.exp
*.map

# ── Compiler output ───────────────────────────────────────────────────────────
*.d
*.i
*.s
*.ii

# ── Test artifacts ────────────────────────────────────────────────────────────
Testing/
CTestTestfile.cmake
LastTest.log

# ── Fuzz artifacts ────────────────────────────────────────────────────────────
corpus/
artifacts/
crash-*
oom-*
timeout-*
slow-*
leak-*

# ── Benchmark output ──────────────────────────────────────────────────────────
benchmark_results/
*.bench

# ── Profiling ─────────────────────────────────────────────────────────────────
perf.data
perf.data.old
*.prof
gmon.out
callgrind.out.*
massif.out.*
heaptrack.*.gz
*.trace

# ── Coverage ──────────────────────────────────────────────────────────────────
*.gcno
*.gcda
*.gcov
lcov.info
coverage/
htmlcov/

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
.vscode/*.code-workspace
.idea/
*.iml
*.suo
*.user
*.sln.docstates
.vs/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
.venv/
env/
.env/
dist/
*.egg-info/
.eggs/

# ── Conan / vcpkg ─────────────────────────────────────────────────────────────
.conan/
conan_provider.cmake
vcpkg_installed/
CMakeUserPresets.json

# ── Generated files ───────────────────────────────────────────────────────────
compile_commands.json
!compile_commands.json

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
desktop.ini

# ── Secrets ───────────────────────────────────────────────────────────────────
.env
.env.*
secrets.*
*.pem
*.key
*.crt
*.p12

# ── Temporary ─────────────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.orig
*.rej
