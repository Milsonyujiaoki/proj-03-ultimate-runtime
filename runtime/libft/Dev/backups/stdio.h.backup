#ifndef STDIO_H
#define STDIO_H

/* Include system stdio.h for standard I/O functions in tests */
#ifdef __GNUC__
#include_next <stdio.h>
#else
#include </usr/include/stdio.h>
#endif

#include <stddef.h>
#include <stdarg.h>

/* File type (already defined in system stdio.h) */
/* typedef struct _IO_FILE FILE; */

/* File position type (already defined in system stdio.h) */
/* typedef long fpos_t; */

/* Standard streams (already defined in system stdio.h) */
/* extern FILE *stdin; */
/* extern FILE *stdout; */
/* extern FILE *stderr; */

/* File positioning (already defined in system stdio.h) */
/* #define SEEK_SET 0 */
/* #define SEEK_CUR 1 */
/* #define SEEK_END 2 */

/* End of file (already defined in system stdio.h) */
/* #define EOF (-1) */

/* Buffer size (already defined in system stdio.h) */
/* #define BUFSIZ 8192 */

/* File operations - our implementations */
FILE *ft_fopen(const char *filename, const char *mode);
FILE *ft_freopen(const char *filename, const char *mode, FILE *stream);
int ft_fclose(FILE *stream);
int ft_fflush(FILE *stream);

/* Formatted output */
int ft_printf(const char *format, ...);
int ft_fprintf(FILE *stream, const char *format, ...);
int ft_sprintf(char *str, const char *format, ...);
int ft_snprintf(char *str, size_t size, const char *format, ...);
int ft_vprintf(const char *format, va_list ap);
int ft_vfprintf(FILE *stream, const char *format, va_list ap);
int ft_vsprintf(char *str, const char *format, va_list ap);
int ft_vsnprintf(char *str, size_t size, const char *format, va_list ap);

/* Formatted input */
int ft_scanf(const char *format, ...);
int ft_fscanf(FILE *stream, const char *format, ...);
int ft_sscanf(const char *str, const char *format, ...);

/* Character I/O */
int ft_fgetc(FILE *stream);
int ft_getc(FILE *stream);
int ft_getchar(void);
char *ft_fgets(char *s, int size, FILE *stream);
char *ft_gets(char *s);
int ft_fputc(int c, FILE *stream);
int ft_putc(int c, FILE *stream);
int ft_putchar(int c);
int ft_fputs(const char *s, FILE *stream);
int ft_puts(const char *s);
int ft_ungetc(int c, FILE *stream);

/* Direct I/O */
size_t ft_fread(void *ptr, size_t size, size_t nmemb, FILE *stream);
size_t ft_fwrite(const void *ptr, size_t size, size_t nmemb, FILE *stream);

/* File positioning */
int ft_fseek(FILE *stream, long offset, int whence);
long ft_ftell(FILE *stream);
void ft_rewind(FILE *stream);
int ft_fgetpos(FILE *stream, fpos_t *pos);
int ft_fsetpos(FILE *stream, const fpos_t *pos);

/* Error handling */
void ft_clearerr(FILE *stream);
int ft_feof(FILE *stream);
int ft_ferror(FILE *stream);
void ft_perror(const char *s);

/* File operations */
int ft_remove(const char *filename);
int ft_rename(const char *old_filename, const char *new_filename);

#endif /* MINI_STDIO_H */
