#ifndef MINI_UNISTD_H
#define MINI_UNISTD_H

#include <stddef.h>

/* Type definitions */
typedef long ssize_t;
typedef long off_t;
typedef int pid_t;
typedef unsigned int uid_t;
typedef unsigned int gid_t;
typedef unsigned int useconds_t;

/* sys/types.h compatibility - define only if not already defined */
#ifndef _SYS_TYPES_H
#define _SYS_TYPES_H
#endif

/* Standard file descriptors */
#define STDIN_FILENO  0
#define STDOUT_FILENO 1
#define STDERR_FILENO 2

/* lseek() whence values */
#ifndef SEEK_SET
#define SEEK_SET 0
#define SEEK_CUR 1
#define SEEK_END 2
#endif

/* access() mode values */
#define F_OK 0  /* Test for existence */
#define X_OK 1  /* Test for execute permission */
#define W_OK 2  /* Test for write permission */
#define R_OK 4  /* Test for read permission */

/* File I/O */
ssize_t ft_read(int fd, void *buf, size_t count);
ssize_t ft_write(int fd, const void *buf, size_t count);
int ft_close(int fd);
off_t ft_lseek(int fd, off_t offset, int whence);

/* File operations */
int ft_access(const char *pathname, int mode);
int ft_unlink(const char *pathname);
int ft_link(const char *oldpath, const char *newpath);
int ft_symlink(const char *target, const char *linkpath);
ssize_t ft_readlink(const char *pathname, char *buf, size_t bufsiz);

/* Directory operations */
int ft_chdir(const char *path);
char *ft_getcwd(char *buf, size_t size);
int ft_rmdir(const char *pathname);

/* Process operations */
pid_t ft_fork(void);
pid_t ft_getpid(void);
pid_t ft_getppid(void);
unsigned int ft_sleep(unsigned int seconds);
int ft_usleep(useconds_t usec);

/* User/Group IDs */
uid_t ft_getuid(void);
uid_t ft_geteuid(void);
gid_t ft_getgid(void);
gid_t ft_getegid(void);
int ft_setuid(uid_t uid);
int ft_setgid(gid_t gid);

/* Process execution */
int ft_execve(const char *pathname, char *const argv[], char *const envp[]);
int ft_execv(const char *pathname, char *const argv[]);
int ft_execvp(const char *file, char *const argv[]);

/* Pipe operations */
int ft_pipe(int pipefd[2]);
int ft_dup(int oldfd);
int ft_dup2(int oldfd, int newfd);

/* System information */
long ft_sysconf(int name);
char *ft_getlogin(void);
int ft_gethostname(char *name, size_t len);

/* Miscellaneous */
int ft_isatty(int fd);
char *ft_ttyname(int fd);

#endif /* MINI_UNISTD_H */
